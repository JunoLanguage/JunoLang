struct Person {
    name: *char,
    age: i32
}

fn main() -> i32 {
    let p: Person = Person {
        name: "Max",
        age: 20,
    };
    printf("Name: %s\n", p.name);
    printf("Age: %d\n", p.age);
    if (p.age >= 18) {
        printf("You are old enough, %s\n", p.name);
    }
    return 0;
}